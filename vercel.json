{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/join", "destination": "/join.html" },
    {"source": "/.well-known/apple-app-site-association", "destination": "/.well-known/apple-app-site-association.json"}
  ]
}