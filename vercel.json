{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "^/\\.well-known/apple-app-site-association$",
      "dest": "/.well-known/apple-app-site-association"
    }
  ],
  "rewrites": [
    { "source": "/join", "destination": "/join.html" }
  ]
}